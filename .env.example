# Telegram
BOT_TOKEN=

# Bootstrap admins (only when admin_users table is empty)
INITIAL_ADMIN_TELEGRAM_IDS=123456789

# Security
SESSION_SECRET=change-me-session-secret-min-32-chars
SESSION_TTL_MINUTES=15
SESSION_ABSOLUTE_TTL_HOURS=8
CSRF_HEADER_NAME=X-CSRF-Token

# Database
POSTGRES_USER=tgscheduler
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tgscheduler
DATABASE_URL=postgresql+asyncpg://tgscheduler:changeme@postgres:5432/tgscheduler

# Valkey
VALKEY_URL=redis://valkey:6379/0

# App
CORS_ORIGINS=http://localhost:5173,http://localhost
API_RELOAD=true
